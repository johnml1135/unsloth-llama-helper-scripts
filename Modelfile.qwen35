# Qwen 2.5 32B with 128k context window
FROM qwen2.5:32b

# Set context window to 128k tokens
PARAMETER num_ctx 131072

# Load all layers to GPU for your RTX 3090
PARAMETER num_gpu 999

# Optimal generation parameters
PARAMETER temperature 0.7
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.05

# System message
SYSTEM You are Qwen 2.5, an AI assistant with 128k token context window capability.
